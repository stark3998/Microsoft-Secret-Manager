# =============================================================================
# Azure / Entra ID
# =============================================================================
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-app-registration-client-id
AZURE_CLIENT_SECRET=your-client-secret-for-local-dev
AZURE_ENVIRONMENT=AzureCloud
# MANAGED_IDENTITY_CLIENT_ID=  # For user-assigned managed identity in Azure

# =============================================================================
# MSAL Token Validation
# =============================================================================
MSAL_CLIENT_ID=your-app-registration-client-id
MSAL_AUTHORITY=https://login.microsoftonline.com/your-tenant-id

# =============================================================================
# Cosmos DB
# =============================================================================
COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
COSMOS_KEY=your-cosmos-key
COSMOS_DATABASE=secret-manager

# For local dev with Cosmos DB Emulator:
# COSMOS_ENDPOINT=https://localhost:8081/
# COSMOS_KEY=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMsEcaGQy67XIw/Jw==

# =============================================================================
# Notifications
# =============================================================================
NOTIFICATION_EMAIL_FROM=no-reply@yourcompany.com
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/your-webhook-url
SLACK_WEBHOOK_URL=
GENERIC_WEBHOOK_URL=

# =============================================================================
# Scheduler
# =============================================================================
SCAN_CRON_EXPRESSION=0 6 * * *
PURGE_CRON_EXPRESSION=0 0 1 * *

# =============================================================================
# ACME Certificate Management
# =============================================================================
ACME_ENABLED=false
ACME_ENDPOINT=https://acme-v02.api.letsencrypt.org/directory
ACME_CONTACTS=admin@yourcompany.com
ACME_KEY_VAULT_URL=https://your-cert-vault.vault.azure.net/
ACME_RENEW_BEFORE_EXPIRY_DAYS=30
ACME_AUTO_RENEW=true
ACME_RENEWAL_CRON=0 0 * * *
# ACME_EAB_KID=          # External Account Binding (ZeroSSL, Google Trust)
# ACME_EAB_HMAC_KEY=
# ACME_PREFERRED_CHAIN=

# =============================================================================
# DNS Providers (configure at least one for ACME)
# =============================================================================
# Azure DNS
DNS_AZURE_SUBSCRIPTION_ID=

# Cloudflare
DNS_CLOUDFLARE_API_TOKEN=

# AWS Route 53
DNS_ROUTE53_ACCESS_KEY=
DNS_ROUTE53_SECRET_KEY=
DNS_ROUTE53_REGION=us-east-1

# =============================================================================
# Observability
# =============================================================================
# APPLICATIONINSIGHTS_CONNECTION_STRING=
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# =============================================================================
# Export
# =============================================================================
EXPORT_MAX_ITEMS=10000

# =============================================================================
# Frontend (prefix with VITE_ for Vite exposure)
# =============================================================================
VITE_AZURE_CLIENT_ID=your-app-registration-client-id
VITE_AZURE_TENANT_ID=your-tenant-id
VITE_API_BASE_URL=http://localhost:8000
